# Supabase Configuration
# Set VITE_USE_SUPABASE=false or leave VITE_SUPABASE_* unset to run without Supabase (mock mode for development).
VITE_USE_SUPABASE=true
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: In mock mode, set this to a fake email to bypass login and use the app with in-memory state only.
# VITE_DEV_USER_EMAIL=dev@localhost

# Example:
# VITE_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
