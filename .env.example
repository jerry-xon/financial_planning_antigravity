# ───────────────────────────────────────────────
# Web app (Vite) — these are inlined at build time
# ───────────────────────────────────────────────
# Set VITE_USE_SUPABASE=false (or leave VITE_SUPABASE_* unset) to run in mock mode for dev.
# Optional: dev | staging | prod — enables staging-only UI when set.
# VITE_APP_STAGE=dev
VITE_USE_SUPABASE=true

# Public site URL — your Vercel deployment URL, or http://localhost:5173 in dev.
VITE_SITE_URL=http://localhost:5173

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API base URL (the separate backend repo deployed to Render).
# Leave blank if you only use Supabase.
# Example: https://finplan-api.onrender.com
VITE_API_URL=

# Razorpay
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id

# Web3Forms — support request emails from the app (ContextualHelpPopup)
# https://web3forms.com/
VITE_WEB3FORMS_ACCESS_KEY=
