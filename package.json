{
  "name": "financial_planning_antigravity",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm -w @finplan/web run dev",
    "dev:api": "npm -w @finplan/api run dev",
    "build": "npm -w @finplan/web run build",
    "start:api": "npm -w @finplan/api run start",
    "lint": "npm -w @finplan/web run lint",
    "preview": "npm -w @finplan/web run preview",
    "test": "npm -w @finplan/web run test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
